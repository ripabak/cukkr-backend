  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "declarationMap": false,
    "skipLibCheck": true,
    "removeComments": true
  },
  "include": [
    "src/app.ts"
  ],
